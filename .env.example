DATABASE_URL=postgresql://postgres:postgres@db:5432/west_santo_travel?schema=public
APP_BASE_URL=http://localhost:3000
SESSION_SECRET=replace-with-a-long-random-secret
KEYCLOAK_ISSUER_URL=http://your-lan-ip:8081/realms/west-santo
KEYCLOAK_ADMIN_USER=admin
KEYCLOAK_ADMIN_PASSWORD=replace-with-keycloak-admin-password
KEYCLOAK_BOOTSTRAP_MODE=development
KEYCLOAK_CLIENT_ID=west-santo-web
KEYCLOAK_CLIENT_SECRET=replace-with-keycloak-client-secret
KEYCLOAK_DEV_LOGIN_EMAIL=admin@westsanto.org
KEYCLOAK_DEV_LOGIN_PASSWORD=replace-with-a-local-dev-password
KEYCLOAK_GOOGLE_CLIENT_ID=replace-with-google-client-id
KEYCLOAK_GOOGLE_CLIENT_SECRET=replace-with-google-client-secret
KEYCLOAK_GOOGLE_HOSTED_DOMAIN=
TELEGRAM_BOT_TOKEN=replace-with-telegram-bot-token
AIRPORT_IMPORT_ENABLED=true
AIRPORT_IMPORT_URL=https://davidmegginson.github.io/ourairports-data/airports.csv
MANDIR_IMPORT_ENABLED=true
