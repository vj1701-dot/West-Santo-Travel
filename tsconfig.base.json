{
  "compilerOptions": {
    "target": "ES2022",
    "lib": [
      "dom",
      "dom.iterable",
      "es2022"
    ],
    "allowJs": false,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "baseUrl": ".",
    "paths": {
      "@west-santo/core/*": [
        "packages/core/src/*"
      ],
      "@west-santo/core": [
        "packages/core/src/index.ts"
      ],
      "@west-santo/data/*": [
        "packages/data/src/*"
      ],
      "@west-santo/data": [
        "packages/data/src/index.ts"
      ]
    }
  }
}
